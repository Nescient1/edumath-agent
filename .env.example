OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=mimo-v2.5
LLM_TIMEOUT_SECONDS=300
LLM_MAX_TOKENS=4096
ENABLE_LLM_DIAGNOSE=1
ENABLE_LLM_OCR_VISION=0
ENABLE_LLM_OCR_REWRITE=0
ENABLE_LLM_DATA_LABELING=0
ENABLE_LLM_PROFILE_ADVICE=1
ENABLE_LLM_QUESTION_GENERATION=0
ENABLE_LLM_LEARNING_PATH=0
ENABLE_PIX2TEXT_OCR=0
PIX2TEXT_DEVICE=
EMBEDDING_MODEL=text-embedding-3-small
ENABLE_OPENAI_EMBEDDING=0
LOCAL_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LOCAL_EMBEDDING_DEVICE=
LOCAL_EMBEDDING_LOCAL_FILES_ONLY=1
CORS_ORIGINS=*
VITE_API_BASE_URL=http://127.0.0.1:8000/api

DATABASE_URL=postgresql+psycopg://edumath:password@localhost:5432/edumath_agent
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=edumath_agent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
